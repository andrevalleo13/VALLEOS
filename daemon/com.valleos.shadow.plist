<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.valleos.shadow</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/Users/andrevalleortega/Desktop/ValleOS/daemon/shadow-daemon.js</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>SHADOW_DAEMON_KEY</key>
    <string>valleos-shadow-daemon</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/shadow-daemon.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/shadow-daemon.err</string>
</dict>
</plist>
